{
  "expo": {
    "name": "LostFindings",
    "slug": "lostfindings",
    "version": "1.0.0",
    "scheme": "lostfindings",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/images/icon.png",
    "splash": {
      "backgroundColor": "#0e0f13"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "LostFindings butuh akses foto untuk upload gambar barang.",
          "cameraPermission": "LostFindings butuh akses kamera untuk foto barang."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lostfindings.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "supabase.co": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.lostfindings.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0659803d-3955-489b-99dc-7ba69a8bad5b"
      }
    },
    "owner": "jadabyanza"
  }
}
